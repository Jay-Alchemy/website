{
  "name": "TBA Funnel Integration",
  "flow": [
    {
      "id": 1,
      "module": "gateway:CustomWebHook",
      "version": 1,
      "parameters": {
        "hook": 2161464,
        "maxResults": 1
      },
      "mapper": {}
    },
    {
      "id": 2,
      "module": "convertkit:addSubscriber",
      "version": 1,
      "parameters": {
        "__IMTCONN__": 8370867
      },
      "mapper": {
        "id": 9327637,
        "email": "{{1.email}}",
        "fields": {
          "core_problem": "{{1.response}}",
          "intake_path": "{{1.path}}"
        }
      }
    },
    {
      "id": 3,
      "module": "builtin:BasicRouter",
      "version": 1,
      "routes": [
        {
          "flow": [
            {
              "id": 4,
              "module": "convertkit:addTagToCustomer",
              "version": 1,
              "parameters": {
                "__IMTCONN__": 8370867
              },
              "filter": {
                "name": "pain",
                "conditions": [
                  [
                    {
                      "a": "{{1.path}}",
                      "o": "text:equal",
                      "b": "pain"
                    }
                  ]
                ]
              },
              "mapper": {
                "email": "{{1.email}}",
                "tags": [
                  18929165
                ]
              }
            }
          ]
        },
        {
          "flow": [
            {
              "id": 5,
              "module": "convertkit:addTagToCustomer",
              "version": 1,
              "parameters": {
                "__IMTCONN__": 8370867
              },
              "filter": {
                "name": "identity",
                "conditions": [
                  [
                    {
                      "a": "{{1.path}}",
                      "o": "text:equal",
                      "b": "identity"
                    }
                  ]
                ]
              },
              "mapper": {
                "email": "{{1.email}}",
                "tags": [
                  18929167
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
